{
  "name": "prd-mcp-server",
  "version": "0.1.0",
  "description": "MCP server for interactive PRD (Product Requirements Document) writing with AI",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "prd-mcp-server": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc && cp -r src/templates dist/ && cp -r src/guides dist/",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "prepublishOnly": "pnpm build",
    "prepare": "pnpm build"
  },
  "keywords": [
    "mcp",
    "prd",
    "product-requirements",
    "specification",
    "ai",
    "llm",
    "model-context-protocol"
  ],
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/haandol/prd-writer"
  },
  "author": "haandol",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.9.0"
  }
}
